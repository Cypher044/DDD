PORT=4000

# URL publique du frontend (CORS + Socket.io). En prod: https://ton-app.vercel.app
CLIENT_URL=http://localhost:5173

# Optionnel: autres origines autorisees (preview deploy, second domaine), separees par des virgules
# CLIENT_URL_EXTRA=https://sunu-bus-git-main-xxx.vercel.app,https://www.tondomaine.sn

JWT_SECRET=remplace-par-une-longue-chaine-aleatoire
GPS_BROADCAST_INTERVAL_MS=5000

# Local
DATABASE_URL=postgresql://sunu_bus:sunu_bus@localhost:5432/sunu_bus

# Supabase: Project Settings > Database > Connection string (URI), mode Session (port 5432) ou Pooler (6543)
# Exemple: postgresql://postgres.[ref]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
# DATABASE_SSL=true est implicite si l’URL contient "supabase"; sinon force avec DATABASE_SSL=true
# DATABASE_SSL=true
